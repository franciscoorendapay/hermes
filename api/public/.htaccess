# Symfony .htaccess with CORS headers for cPanel/LiteSpeed

# Basic Auth com exceções para rotas públicas da API
# SetEnvIf + Require env tem suporte em Apache e LiteSpeed (Require expr com regex não funciona no LiteSpeed)
SetEnvIf Request_URI "^/api/places" no_auth
SetEnvIf Request_URI "^/api/geocode" no_auth
SetEnvIf Request_URI "^/api/auth/login" no_auth
SetEnvIf Request_URI "^/api/auth/refresh" no_auth
SetEnvIf Request_URI "^/api/auth/setup-password" no_auth

AuthType Basic
AuthName "Restricted Area"
AuthUserFile /home/orendapay/api.hermes.orendapay.com.br/public/.htpasswd
<RequireAny>
    Require valid-user
    Require env no_auth
</RequireAny>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Passa o header Authorization ao PHP (necessário em LiteSpeed/FastCGI)
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle OPTIONS preflight (CORS)
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule .* - [R=204,L]

    # Redirect to index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# CORS Headers
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, X-API-Key"
    Header always set Access-Control-Expose-Headers "Content-Length, Content-Type, Link"
    Header always set Access-Control-Max-Age "3600"
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# PHP Settings
<IfModule mod_php.c>
    php_value upload_max_filesize 50M
    php_value post_max_size 50M
    php_value max_execution_time 300
    php_value memory_limit 256M
</IfModule>
