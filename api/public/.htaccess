# Symfony .htaccess with CORS headers for cPanel/LiteSpeed

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bypass Basic Auth for OPTIONS preflight (CORS)
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule .* - [E=NO_AUTH:1,L]

    # Redirect to index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Bypass Basic Auth se vier o header secreto da aplicação React
SetEnvIfNoCase X-API-Key "Sy7xP!k2mNqR9vLw" NO_AUTH

# Basic Auth
AuthType Basic
AuthName "API Access"
AuthUserFile /home2/hermesorendapayc/hermes2/api/public/.htpasswd
Require valid-user

# Satisfy Any: passa se tiver IP/env liberado OU se autenticar com Basic Auth
Order Allow,Deny
Allow from env=NO_AUTH
Satisfy Any

# CORS Headers
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, X-API-Key"
    Header always set Access-Control-Expose-Headers "Content-Length, Content-Type, Link"
    Header always set Access-Control-Max-Age "3600"
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# PHP Settings
<IfModule mod_php.c>
    php_value upload_max_filesize 50M
    php_value post_max_size 50M
    php_value max_execution_time 300
    php_value memory_limit 256M
</IfModule>
